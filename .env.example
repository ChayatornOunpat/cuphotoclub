# Session secret for nuxt-auth-utils (any long random string)
NUXT_SESSION_PASSWORD=replace-with-a-long-random-string-32-chars-min

# Public canonical site URL. Use the deployed origin in production.
NUXT_PUBLIC_SITE_URL=https://cuphotoclub.com

# Production defaults to real-data-only. Set false only when intentionally previewing mock content.
NUXT_REAL_DATA_ONLY=true
NUXT_PUBLIC_REAL_DATA_ONLY=true

# Google OAuth for admin login (optional — leave blank to use password login only)
NUXT_OAUTH_GOOGLE_CLIENT_ID=
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=

# Direct browser-to-R2 uploads.
# Create an R2 API token with object read/write access to the bucket, then set these
# as deployment secrets/env vars. The browser uploads bytes directly to R2; the app
# only signs URLs and finalizes upload manifests.
NUXT_R2_ACCOUNT_ID=
NUXT_R2_BUCKET_NAME=cuphotoclub-blob
NUXT_R2_ACCESS_KEY_ID=
NUXT_R2_SECRET_ACCESS_KEY=

# Dev owner account, auto-seeded on first `pnpm dev`
ADMIN_SEED_EMAIL=admin@cuphotoclub.local
ADMIN_SEED_PASSWORD=changeme123
